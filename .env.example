# Copy these private settings to `.env` or the ignored `.dev.vars` file.
# Screenshot capture is reuse-only in local development unless explicitly enabled.
NUXT_SCREENSHOT_CAPTURE_ENABLED=false
NUXT_SCREENSHOT_REQUEST_CAPTURE_ENABLED=false

# `npm run dev` defaults to the local Browserless proxy. Add `,browser-run`
# deliberately when testing the chained Cloudflare fallback.
NUXT_SCREENSHOT_PROVIDERS=browserless-proxy
NUXT_SCREENSHOT_PROVIDER_STRATEGY=ordered
NUXT_SCREENSHOT_BROWSERLESS_PROXY_URL=https://screenshots.dev.localhost/v1/screenshots
NUXT_SCREENSHOT_BROWSERLESS_PROXY_TOKEN=

# One bounded full-page WebP is reused by feeds, detail pages, and social metadata.
NUXT_SCREENSHOT_PREVIEW_HEIGHT=11111
NUXT_SCREENSHOT_PREVIEW_WEBP_QUALITY=55
NUXT_SCREENSHOT_PREVIEW_MAX_BYTES=2000000

# Required only when exercising the authenticated background-agent endpoints.
HN42_SCREENSHOT_AGENT_TOKEN=
