{
  "name": "hn42",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "NUXT_SCREENSHOT_CAPTURE_ENABLED=false npm run build && wrangler dev",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "typecheck": "nuxi typecheck",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types --include-runtime false",
    "cf:screenshots:bootstrap": "bash scripts/bootstrap-cloudflare-screenshots.sh",
    "cf:screenshots:reset-cache": "node scripts/reset-cloudflare-screenshot-cache.mjs"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "date-fns": "^4.4.0",
    "nuxt": "^4.4.8",
    "nuxt-lucide-icons": "^2.1.0",
    "pos": "^0.4.2",
    "stemmer": "^2.0.1",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/node": "^26.1.1",
    "nitro-cloudflare-dev": "^0.2.2",
    "nitropack": "^2.13.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.110.0"
  }
