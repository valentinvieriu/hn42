{
  "name": "hn-glance",
  "private": true,
  "packageManager": "npm@10.9.2",
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "build:screenshot-agent": "tsc -p capture-agent/tsconfig.json && esbuild capture-agent/src/index.ts --bundle --format=esm --platform=node --target=node24 --outfile=capture-agent/dist/index.mjs",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "npm run build && wrangler dev",
    "postinstall": "nuxt prepare",
    "test": "vitest run",
    "typecheck": "nuxi typecheck",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types --include-runtime false",
    "cf:screenshots:bootstrap": "bash scripts/bootstrap-cloudflare-screenshots.sh",
    "cf:screenshots:jobs:bootstrap": "bash scripts/bootstrap-cloudflare-screenshot-jobs.sh",
    "cf:screenshots:scheduler:deploy": "wrangler deploy --config workers/screenshot-scheduler/wrangler.jsonc",
    "cf:screenshots:scheduler:dry-run": "wrangler deploy --dry-run --config workers/screenshot-scheduler/wrangler.jsonc",
    "cf:screenshots:scheduler:typegen": "wrangler types workers/screenshot-scheduler/worker-configuration.d.ts --config workers/screenshot-scheduler/wrangler.jsonc --env-interface SchedulerEnv --include-runtime false"
  },
  "dependencies": {
    "@lucide/vue": "^1.24.0",
    "@nuxtjs/color-mode": "^4.0.1",
    "@nuxtjs/google-fonts": "^3.2.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "nuxt": "^4.4.8",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "@types/node": "^26.1.1",
    "nitro-cloudflare-dev": "^0.2.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7",
    "wrangler": "^4.110.0"
  }
}
