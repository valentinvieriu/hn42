# Required Cloudflare Queue credentials.
CF_ACCOUNT_ID=
CF_QUEUE_ID=
CF_QUEUES_API_TOKEN=

# Required HN Glance Worker endpoint and its shared agent secret.
HN42_BASE_URL=https://hn-glance.vv42.workers.dev
HN_GLANCE_SCREENSHOT_AGENT_TOKEN=

# Required local Browserless screenshot API credentials.
SCREENSHOT_API_URL=
SCREENSHOT_API_TOKEN=

# Optional agent tuning. These values match the built-in defaults.
CAPTURE_CONCURRENCY=4
QUEUE_BATCH_SIZE=4
QUEUE_VISIBILITY_TIMEOUT_MS=180000
QUEUE_IDLE_POLL_MS=30000
PORT=3002
