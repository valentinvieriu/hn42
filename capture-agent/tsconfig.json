{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2023",
    "types": ["node"]
  },
  "include": [
    "src/**/*.ts",
    "../shared/utils/hn.ts",
    "../shared/utils/screenshot.ts",
    "../shared/utils/screenshotJobs.ts"
  ]
}
